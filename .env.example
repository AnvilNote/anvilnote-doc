# Feedback form (src/app/api/feedback) — Supabase + Resend.
# Fill in .env locally; set these as Vercel project env vars for deploys.

# Supabase project URL (Project Settings -> API).
SUPABASE_URL=

# Supabase SECRET / service_role key — NOT the publishable/anon key.
# Bypasses RLS; server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key, used to send the feedback confirmation email
# from no-reply@anvilnote.org.
RESEND_API_KEY=

# Public (safe to expose) — used only for image uploads (feedback screenshots)
# via a server-issued signed upload URL, never for table access.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin dashboard (/admin) — single hardcoded operator account, no user table.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Random secret used only to sign the admin session cookie (HMAC) — generate
# a fresh one per environment, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=
